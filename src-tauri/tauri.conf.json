{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Daily Cat Wallpaper",
  "version": "0.1.0",
  "identifier": "com.dailycat.wallpaper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Daily Cat Wallpaper",
        "width": 1120,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Lifestyle",
    "shortDescription": "Automatic cat wallpaper freedom for your desktop.",
    "longDescription": "Daily Cat Wallpaper is a cross-platform Rust desktop app that rotates healing cat wallpapers, supports breed and interaction preferences, and keeps Windows, macOS, and Linux desktops cozy."
  }
}
